{
  "info": {
    "_postman_id": "f934dd11-4465-4921-ae50-3cc1e8fd47df",
    "name": "Agrisano Backend - Cosecha",
    "description": "Coleccion para probar el modulo de cosecha. Importar en Postman, configurar variables de email/password/tenant, mesaId y pesoKg, y ejecutar Login antes de los endpoints protegidos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
          "if (!pm.request.headers.has('Content-Type') && ['POST', 'PATCH', 'PUT'].includes(pm.request.method)) {",
          "  pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "description": "Usar si TENANCY_REQUIRED=true o si el login necesita contexto de tenant."
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "description": "Opcional, segun configuracion TENANCY_HEADER.",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Obtiene access_token y refresh_token. El test los guarda en las variables token y refreshToken."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Refresh exitoso', function () {",
                  "  pm.response.to.be.success;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Renueva tokens y actualiza variables."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Prueba rapida del bearer token."
          }
        }
      ]
    },
    {
      "name": "Cosecha",
      "description": "Endpoints de src/modules/cosecha/cosecha.controller.ts. Requieren JWT. Registrar cosecha requiere rol operario, supervisor o admin_global. Listar y consultar requiere usuario autenticado.",
      "item": [
        {
          "name": "Registrar cosecha",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Cosecha registrada', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  if (json.data.cosecha && json.data.cosecha.id) pm.collectionVariables.set('cosechaId', json.data.cosecha.id);",
                  "  if (json.data.cosecha && json.data.cosecha.mesa_id) pm.collectionVariables.set('mesaId', json.data.cosecha.mesa_id);",
                  "  if (json.data.cosecha && json.data.cosecha.tunel_id) pm.collectionVariables.set('tunelId', json.data.cosecha.tunel_id);",
                  "  if (json.data.tunel_id) pm.collectionVariables.set('tunelId', json.data.tunel_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mesa_id\": \"{{mesaId}}\",\n  \"peso_kg\": {{pesoKg}},\n  \"observaciones\": \"{{observaciones}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cosecha",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cosecha"
              ]
            },
            "description": "Registra una cosecha. La mesa debe estar activa y en posicion_actual 1. El backend crea la cosecha, cambia la mesa a en_cosecha, deja posicion_actual null, recalcula posiciones FIFO del tunel, escribe historial y auditoria."
          }
        },
        {
          "name": "Listar cosechas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cosecha?page={{page}}&limit={{limit}}&mesa_id={{mesaId}}&tunel_id={{tunelId}}&fecha_desde={{fechaDesde}}&fecha_hasta={{fechaHasta}}&sortOrder={{sortOrder}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cosecha"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                },
                {
                  "key": "mesa_id",
                  "value": "{{mesaId}}",
                  "description": "Opcional. Filtra por mesa.",
                  "disabled": true
                },
                {
                  "key": "tunel_id",
                  "value": "{{tunelId}}",
                  "description": "Opcional. Filtra por tunel.",
                  "disabled": true
                },
                {
                  "key": "fecha_desde",
                  "value": "{{fechaDesde}}",
                  "description": "Opcional ISO 8601, por ejemplo 2026-06-01T00:00:00.000Z.",
                  "disabled": true
                },
                {
                  "key": "fecha_hasta",
                  "value": "{{fechaHasta}}",
                  "description": "Opcional ISO 8601.",
                  "disabled": true
                },
                {
                  "key": "sortOrder",
                  "value": "{{sortOrder}}",
                  "description": "ASC o DESC. El backend ordena por fecha_hora."
                }
              ]
            },
            "description": "Lista cosechas del tenant actual. Devuelve respuesta paginada."
          }
        },
        {
          "name": "Obtener cosecha por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Cosecha obtenida', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cosecha/{{cosechaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cosecha",
                "{{cosechaId}}"
              ]
            },
            "description": "Obtiene una cosecha por ID dentro del tenant actual."
          }
        },
        {
          "name": "Listar cosechas por mesa",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/mesas/{{mesaId}}/cosechas?page={{page}}&limit={{limit}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "mesas",
                "{{mesaId}}",
                "cosechas"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                }
              ]
            },
            "description": "Lista cosechas de una mesa. Valida que la mesa exista en el tenant. El backend ordena por fecha_hora DESC."
          }
        },
        {
          "name": "Error esperado - peso invalido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Debe fallar por peso invalido', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mesa_id\": \"{{mesaId}}\",\n  \"peso_kg\": 0,\n  \"observaciones\": \"Caso negativo: peso invalido\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cosecha",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cosecha"
              ]
            },
            "description": "Caso negativo de DTO: peso_kg debe ser mayor o igual a 0.001."
          }
        },
        {
          "name": "Error esperado - mesa no disponible",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Debe fallar por mesa no disponible', function () {",
                  "  pm.response.to.have.status(422);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Codigo COSECHA_MESA_NO_DISPONIBLE', function () {",
                  "  pm.expect(json.error && json.error.code).to.eql('COSECHA_MESA_NO_DISPONIBLE');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mesa_id\": \"{{mesaId}}\",\n  \"peso_kg\": {{pesoKg}},\n  \"observaciones\": \"Caso negativo: mesa no esta activa en posicion 1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cosecha",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cosecha"
              ]
            },
            "description": "Caso negativo de negocio. Para que falle con COSECHA_MESA_NO_DISPONIBLE, usar una mesa que no este activa o que no tenga posicion_actual 1."
          }
        }
      ]
    }
  ],
