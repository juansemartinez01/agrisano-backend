                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"{{establecimientoNombre}}\",\n  \"ubicacion\": \"{{establecimientoUbicacion}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/establecimientos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "establecimientos"
              ]
            },
            "description": "Requiere rol admin_global. Body: nombre obligatorio max 150, ubicacion opcional max 300."
          }
        },
        {
          "name": "Actualizar establecimiento",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
