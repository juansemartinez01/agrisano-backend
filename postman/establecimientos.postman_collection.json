            "url": {
              "raw": "{{baseUrl}}/establecimientos/{{establecimientoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "establecimientos",
                "{{establecimientoId}}"
              ]
            },
            "description": "Requiere rol admin_global. Todos los campos son opcionales. activo debe ser boolean."
          }
        },
