{
  "info": {
    "_postman_id": "f5b6fd01-59b4-4a85-9d81-3892a307c2f1",
    "name": "Agrisano Backend - Establecimientos",
    "description": "Coleccion para probar el modulo de establecimientos. Importar en Postman, configurar variables de email/password/tenant y ejecutar Login antes de los endpoints protegidos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
          "if (!pm.request.headers.has('Content-Type') && ['POST', 'PATCH', 'PUT'].includes(pm.request.method)) {",
          "  pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "description": "Usar si TENANCY_REQUIRED=true o si el login necesita contexto de tenant."
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "description": "Opcional, segun configuracion TENANCY_HEADER.",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Obtiene access_token y refresh_token. El test los guarda en las variables token y refreshToken."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Refresh exitoso', function () {",
                  "  pm.response.to.be.success;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Renueva tokens y actualiza variables."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Prueba rapida del bearer token."
          }
        }
      ]
    },
    {
      "name": "Establecimientos",
      "description": "Endpoints de src/modules/establecimientos/establecimientos.controller.ts. Requieren JWT. Lectura: admin_global, supervisor u operario. Escritura/asignaciones: admin_global.",
      "item": [
        {
          "name": "Listar establecimientos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Respuesta paginada', function () {",
                  "  pm.response.to.be.success;",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('ok', true);",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data[0] && json.data[0].id) {",
                  "  pm.collectionVariables.set('establecimientoId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/establecimientos?page={{page}}&limit={{limit}}&q={{search}}&activo={{activo}}&sortBy={{sortBy}}&sortOrder={{sortOrder}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "establecimientos"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                },
                {
                  "key": "q",
                  "value": "{{search}}",
                  "description": "Busca por nombre."
                },
                {
                  "key": "activo",
                  "value": "{{activo}}",
                  "description": "true o false."
                },
                {
                  "key": "sortBy",
                  "value": "{{sortBy}}",
                  "description": "Permitidos: nombre, created_at."
                },
                {
                  "key": "sortOrder",
                  "value": "{{sortOrder}}",
                  "description": "ASC o DESC."
                }
              ]
            }
          }
        },
        {
          "name": "Obtener establecimiento por ID",
          "request": {
            "method": "GET",
            "header": [
              {
