    "name": "Agrisano Backend - Mesas",
    "description": "Coleccion para probar el modulo de mesas e historial. Importar en Postman, configurar variables de email/password/tenant, establecimientoId y tunelId, y ejecutar Login antes de los endpoints protegidos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
          "if (!pm.request.headers.has('Content-Type') && ['POST', 'PATCH', 'PUT'].includes(pm.request.method)) {",
          "  pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "description": "Usar si TENANCY_REQUIRED=true o si el login necesita contexto de tenant."
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "description": "Opcional, segun configuracion TENANCY_HEADER.",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Obtiene access_token y refresh_token. El test los guarda en las variables token y refreshToken."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Refresh exitoso', function () {",
                  "  pm.response.to.be.success;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Renueva tokens y actualiza variables."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Prueba rapida del bearer token."
          }
        }
      ]
    },
    {
      "name": "Mesas",
      "description": "Endpoints de src/modules/mesas/mesas.controller.ts. Requieren JWT. Listar/obtener/historial: cualquier usuario autenticado. Crear/actualizar/baja/reactivar: supervisor o admin_global. Eliminar: admin_global y solo si la mesa esta en baja.",
      "item": [
        {
          "name": "Listar mesas",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Respuesta paginada', function () {",
                  "  pm.response.to.be.success;",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('ok', true);",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data[0] && json.data[0].id) {",
                  "  pm.collectionVariables.set('mesaId', json.data[0].id);",
                  "}",
                  "if (json.data && json.data[0] && json.data[0].codigo_qr) {",
                  "  pm.collectionVariables.set('codigoQr', json.data[0].codigo_qr);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/mesas?page={{page}}&limit={{limit}}&establecimiento_id={{establecimientoId}}&tunel_id={{tunelId}}&estado={{mesaEstado}}&activo={{activo}}&q={{search}}&sortBy={{sortBy}}&sortOrder={{sortOrder}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "mesas"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                },
                {
                  "key": "establecimiento_id",
                  "value": "{{establecimientoId}}"
                },
                {
                  "key": "tunel_id",
                  "value": "{{tunelId}}"
                },
                {
                  "key": "estado",
                  "value": "{{mesaEstado}}",
                  "description": "Valores permitidos: activa, en_cosecha, baja."
                },
                {
                  "key": "activo",
                  "value": "{{activo}}"
                },
                {
                  "key": "q",
                  "value": "{{search}}",
                  "description": "Busca por codigo_qr."
                },
                {
                  "key": "sortBy",
                  "value": "{{sortBy}}",
                  "description": "Permitidos: created_at, posicion_actual, estado."
                },
                {
                  "key": "sortOrder",
                  "value": "{{sortOrder}}",
                  "description": "ASC o DESC."
                }
              ]
            },
            "description": "Lista mesas no eliminadas del tenant actual."
          }
        },
        {
          "name": "Crear mesa",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Creada', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('mesaId', json.data.id);",
                  "}",
                  "if (json.data && json.data.codigo_qr) {",
                  "  pm.collectionVariables.set('codigoQr', json.data.codigo_qr);",
                  "}",
                  "if (json.data && json.data.posicion_actual !== undefined) {",
                  "  pm.collectionVariables.set('posicionActual', String(json.data.posicion_actual));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"establecimiento_id\": \"{{establecimientoId}}\",\n  \"tunel_id\": \"{{tunelId}}\",\n  \"plantas_estimadas\": {{plantasEstimadas}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/mesas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "mesas"
              ]
            },
            "description": "Requiere rol supervisor o admin_global. Genera codigo_qr automatico y asigna posicion_actual siguiente dentro del tunel."
          }
        },
