          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Solo baja delete', function () {",
                  "  pm.response.to.have.status(409);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error.code).to.eql('MESA_SOLO_BAJA_DELETE');",
                  "});"
                ]
              }
            }
