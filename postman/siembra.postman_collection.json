{
  "info": {
    "_postman_id": "590402c1-8c52-4f49-b1fc-dc69fc5c3a88",
    "name": "Agrisano Backend - Siembra y Bandejas",
    "description": "Coleccion para probar el modulo de siembra y bandejas. Importar en Postman, configurar variables de email/password/tenant, establecimientoId, loteSemillaId y loteSustratoId, y ejecutar Login antes de los endpoints protegidos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
          "if (!pm.request.headers.has('Content-Type') && ['POST', 'PATCH', 'PUT'].includes(pm.request.method)) {",
          "  pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "description": "Usar si TENANCY_REQUIRED=true o si el login necesita contexto de tenant."
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "description": "Opcional, segun configuracion TENANCY_HEADER.",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Obtiene access_token y refresh_token. El test los guarda en las variables token y refreshToken."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Refresh exitoso', function () {",
                  "  pm.response.to.be.success;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Renueva tokens y actualiza variables."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Prueba rapida del bearer token."
          }
        }
      ]
    },
    {
      "name": "Siembras",
      "description": "Endpoints de src/modules/siembra/siembra.controller.ts. Requieren JWT. Crear: operario, supervisor o admin_global. Actualizar observaciones: supervisor o admin_global. Eliminar: admin_global.",
      "item": [
        {
          "name": "Listar siembras",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Respuesta paginada', function () {",
                  "  pm.response.to.be.success;",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('ok', true);",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data[0] && json.data[0].id) {",
                  "  pm.collectionVariables.set('siembraId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/siembras?page={{page}}&limit={{limit}}&establecimiento_id={{establecimientoId}}&fecha_desde={{fechaDesde}}&fecha_hasta={{fechaHasta}}&sortBy={{siembraSortBy}}&sortOrder={{sortOrder}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "siembras"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                },
                {
                  "key": "establecimiento_id",
                  "value": "{{establecimientoId}}",
                  "description": "UUID del establecimiento."
                },
                {
                  "key": "fecha_desde",
                  "value": "{{fechaDesde}}",
                  "description": "Fecha ISO YYYY-MM-DD."
                },
                {
                  "key": "fecha_hasta",
                  "value": "{{fechaHasta}}",
                  "description": "Fecha ISO YYYY-MM-DD."
                },
                {
                  "key": "sortBy",
                  "value": "{{siembraSortBy}}",
                  "description": "Permitidos: fecha, created_at."
                },
                {
                  "key": "sortOrder",
                  "value": "{{sortOrder}}",
                  "description": "ASC o DESC."
                }
              ]
            },
            "description": "Lista siembras del tenant actual. Requiere JWT."
          }
        },
        {
          "name": "Crear siembra con bandejas",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Creada', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('siembraId', json.data.id);",
                  "}",
                  "if (json.data && json.data.bandejas && json.data.bandejas[0] && json.data.bandejas[0].id) {",
                  "  pm.collectionVariables.set('bandejaId', json.data.bandejas[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"establecimiento_id\": \"{{establecimientoId}}\",\n  \"fecha\": \"{{fechaSiembra}}\",\n  \"observaciones\": \"{{siembraObservaciones}}\",\n  \"bandejas\": [\n    {\n      \"lote_semilla_id\": \"{{loteSemillaId}}\",\n      \"lote_sustrato_id\": \"{{loteSustratoId}}\",\n      \"cantidad\": {{cantidadBandejas}}\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/siembras",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "siembras"
              ]
            },
            "description": "Requiere rol operario, supervisor o admin_global. Crea una siembra y genera bandejas en estado en_nursery. lote_semilla_id debe ser lote tipo semilla y lote_sustrato_id debe ser lote tipo sustrato."
          }
        },
        {
          "name": "Obtener siembra por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Siembra encontrada', function () {",
                  "  pm.response.to.be.success;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.bandejas && json.data.bandejas[0] && json.data.bandejas[0].id) {",
                  "  pm.collectionVariables.set('bandejaId', json.data.bandejas[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/siembras/{{siembraId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "siembras",
                "{{siembraId}}"
              ]
            },
            "description": "Devuelve la siembra con sus bandejas y referencias basicas a lote_semilla/lote_sustrato."
          }
        },
        {
          "name": "Actualizar observaciones de siembra",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
