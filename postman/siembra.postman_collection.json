              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "siembras",
                "{{siembraId}}"
              ]
            },
            "description": "Requiere rol supervisor o admin_global. Solo se puede modificar observaciones."
          }
        },
        {
          "name": "Intentar modificar campo inmutable (debe fallar)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Campo inmutable', function () {",
                  "  pm.response.to.have.status(400);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error.code).to.eql('SIEMBRA_FIELD_IMMUTABLE');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"{{fechaSiembra}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/siembras/{{siembraId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "siembras",
                "{{siembraId}}"
              ]
            },
            "description": "Caso negativo para validar la regla: solo se puede modificar observaciones."
          }
        },
        {
          "name": "Crear siembra con lote semilla incorrecto (debe fallar)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Tipo de lote incorrecto', function () {",
                  "  pm.response.to.have.status(422);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error.code).to.eql('LOTE_TIPO_INCORRECTO');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"establecimiento_id\": \"{{establecimientoId}}\",\n  \"fecha\": \"{{fechaSiembra}}\",\n  \"observaciones\": \"Caso negativo: semilla incorrecta\",\n  \"bandejas\": [\n    {\n      \"lote_semilla_id\": \"{{loteSustratoId}}\",\n      \"lote_sustrato_id\": \"{{loteSustratoId}}\",\n      \"cantidad\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/siembras",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "siembras"
              ]
            },
            "description": "Caso negativo opcional: usa un lote sustrato como semilla y debe devolver LOTE_TIPO_INCORRECTO."
          }
        },
        {
          "name": "Eliminar siembra",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/siembras/{{siembraId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "siembras",
                "{{siembraId}}"
              ]
            },
            "description": "Requiere rol admin_global. Hace soft delete de la siembra y sus bandejas. Si tiene bandejas trasplantadas responde 409 SIEMBRA_HAS_TRASPLANTADAS."
          }
        }
      ]
