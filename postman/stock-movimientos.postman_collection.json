              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quimico_id\": \"{{quimicoId}}\",\n  \"tipo\": \"egreso_manual\",\n  \"cantidad\": {{cantidadEgreso}},\n  \"observaciones\": \"{{observacionesEgreso}}\",\n  \"fecha\": \"{{fechaMovimiento}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stock-movimientos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "stock-movimientos"
              ]
            },
            "description": "Requiere rol supervisor o admin_global. Crea movimiento tipo egreso_manual y resta stock_actual del quimico."
          }
        },
        {
          "name": "Crear egreso que deja stock negativo",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Egreso creado con warning', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.warning).to.eql('Stock resultante negativo');",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.movimiento && json.data.movimiento.id) {",
                  "  pm.collectionVariables.set('movimientoId', json.data.movimiento.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quimico_id\": \"{{quimicoId}}\",\n  \"tipo\": \"egreso_manual\",\n  \"cantidad\": {{cantidadEgresoGrande}},\n  \"observaciones\": \"Caso warning: stock negativo\",\n  \"fecha\": \"{{fechaMovimiento}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stock-movimientos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "stock-movimientos"
              ]
            },
            "description": "Caso de negocio: el backend permite stock negativo y devuelve warning Stock resultante negativo."
          }
        },
        {
          "name": "Crear movimiento con cantidad invalida (debe fallar)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Cantidad invalida', function () {",
                  "  pm.response.to.have.status(400);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error.code).to.eql('BAD_REQUEST');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
