            "body": {
              "mode": "raw",
              "raw": "{\n  \"quimico_id\": \"{{quimicoId}}\",\n  \"tipo\": \"ingreso\",\n  \"cantidad\": 0,\n  \"fecha\": \"{{fechaMovimiento}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stock-movimientos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "stock-movimientos"
              ]
            },
            "description": "Caso negativo: cantidad debe ser >= 0.001."
