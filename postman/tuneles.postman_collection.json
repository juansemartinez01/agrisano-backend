              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"establecimiento_id\": \"{{establecimientoId}}\",\n  \"nombre\": \"Tunel Capacidad Invalida\",\n  \"capacidad_maxima\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tuneles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tuneles"
              ]
            },
            "description": "Caso negativo: capacidad_maxima debe ser entero >= 1."
          }
        },
        {
          "name": "Eliminar tunel",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenantKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tuneles/{{tunelId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tuneles",
                "{{tunelId}}"
              ]
            },
            "description": "Requiere rol admin_global. Hace soft delete."
          }
        }
      ]
    },
