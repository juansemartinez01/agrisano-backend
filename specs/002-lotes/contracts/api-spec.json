{
  "openapi": "3.0.3",
  "info": {
    "title": "Lotes API — M02",
    "version": "1.0.0",
    "description": "Endpoints for managing seed and substrate lots within a tenant."
  },
  "tags": [
    { "name": "Lotes", "description": "Lot CRUD operations" },
    { "name": "Admin", "description": "Admin panel endpoints (admin_global only)" }
  ],
  "security": [{ "bearerAuth": [] }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "LoteTipo": {
        "type": "string",
        "enum": ["semilla", "sustrato"],
        "description": "Lot type discriminator. Immutable after creation."
      },
      "Lote": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "tenant_id": { "type": "string", "format": "uuid" },
          "tipo": { "$ref": "#/components/schemas/LoteTipo" },
          "numero_lote": { "type": "string", "maxLength": 100 },
          "proveedor": { "type": "string", "maxLength": 200, "nullable": true },
          "observaciones": { "type": "string", "nullable": true },
          "activo": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "deleted_at": { "type": "string", "format": "date-time", "nullable": true }
        },
        "required": ["id", "tenant_id", "tipo", "numero_lote", "activo", "created_at", "updated_at"]
      },
      "CreateLoteDto": {
        "type": "object",
        "properties": {
          "tipo": { "$ref": "#/components/schemas/LoteTipo" },
          "numero_lote": { "type": "string", "minLength": 1, "maxLength": 100 },
          "proveedor": { "type": "string", "maxLength": 200, "nullable": true },
          "observaciones": { "type": "string", "nullable": true }
        },
        "required": ["tipo", "numero_lote"]
      },
      "UpdateLoteDto": {
        "type": "object",
        "description": "All fields optional. `tipo` is excluded — submitting it returns 400.",
        "properties": {
          "numero_lote": { "type": "string", "minLength": 1, "maxLength": 100 },
          "proveedor": { "type": "string", "maxLength": 200, "nullable": true },
          "observaciones": { "type": "string", "nullable": true },
          "activo": { "type": "boolean" }
        }
      },
      "PagedLotes": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": true },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Lote" } },
          "meta": {
            "type": "object",
            "properties": {
              "page": { "type": "integer" },
              "limit": { "type": "integer" },
              "total": { "type": "integer" }
            }
          }
        }
      },
      "SingleLote": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "data": { "$ref": "#/components/schemas/Lote" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": {}
            }
          }
        }
      }
    },
    "parameters": {
      "LoteId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" }
      }
    }
  },
  "paths": {
    "/lotes": {
      "get": {
        "tags": ["Lotes"],
        "summary": "List lots (paginated, filterable, searchable) — all authenticated users",
        "description": "Text search (q) matches numero_lote OR proveedor (case-insensitive, partial). Supports tipo and activo filters. Returns all tenant lots.",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 200 } },
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Search term — OR match across numero_lote and proveedor" },
          { "name": "tipo", "in": "query", "schema": { "$ref": "#/components/schemas/LoteTipo" } },
          { "name": "activo", "in": "query", "schema": { "type": "boolean" } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["numero_lote", "proveedor", "created_at"] } },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["ASC", "DESC"] } }
        ],
        "responses": {
          "200": { "description": "Paginated lot list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedLotes" } } } },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Lotes"],
        "summary": "Create lot (supervisor, admin_global)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateLoteDto" } } }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SingleLote" } } } },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden — operario cannot create lots" },
          "409": {
            "description": "Conflict — numero_lote already exists for this tipo in this tenant among non-deleted lots",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/lotes/{id}": {
      "get": {
        "tags": ["Lotes"],
        "summary": "Get lot by ID — all authenticated users",
        "parameters": [{ "$ref": "#/components/parameters/LoteId" }],
        "responses": {
          "200": { "description": "Lot found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SingleLote" } } } },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Lot not found in tenant" }
        }
      },
      "patch": {
        "tags": ["Lotes"],
        "summary": "Update lot (supervisor, admin_global)",
        "description": "Partial update. Submitting `tipo` in the body returns 400 LOTE_TIPO_IMMUTABLE.",
        "parameters": [{ "$ref": "#/components/parameters/LoteId" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateLoteDto" } } }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SingleLote" } } } },
          "400": { "description": "Validation error or LOTE_TIPO_IMMUTABLE if tipo supplied" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Not found" },
          "409": { "description": "LOTE_NUMERO_DUPLICADO if new numero_lote conflicts" }
        }
      },
      "delete": {
        "tags": ["Lotes"],
        "summary": "Soft-delete lot (admin_global only)",
        "parameters": [{ "$ref": "#/components/parameters/LoteId" }],
        "responses": {
          "200": { "description": "Deleted", "content": { "application/json": { "schema": { "type": "object", "properties": { "ok": { "type": "boolean" }, "data": { "type": "object", "properties": { "deleted": { "type": "boolean" } } } } } } } },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Not found" },
          "409": { "description": "LOTE_REFERENCED_BY_BANDEJA — lot is referenced by one or more bandejas" }
        }
      }
    },
    "/admin/lotes": {
      "get": {
        "tags": ["Admin"],
        "summary": "Admin panel: list all tenant lots (admin_global only)",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 200 } },
          { "name": "q", "in": "query", "schema": { "type": "string" } },
          { "name": "tipo", "in": "query", "schema": { "$ref": "#/components/schemas/LoteTipo" } },
          { "name": "activo", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": { "description": "Paginated lot list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedLotes" } } } },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden — admin_global only" }
        }
      }
    }
  }
}
