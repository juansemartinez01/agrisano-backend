{
  "openapi": "3.0.3",
  "info": {
    "title": "Siembra API — M03",
    "version": "1.0.0",
    "description": "Endpoints for managing seeding events and tray (bandeja) inventory."
  },
  "tags": [
    { "name": "Siembras", "description": "Seeding event operations" },
    { "name": "Bandejas", "description": "Tray nursery inventory" }
  ],
  "security": [{ "bearerAuth": [] }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "BandejaEstado": {
        "type": "string",
        "enum": ["en_nursery", "trasplantada"]
      },
      "LoteRef": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "numero_lote": { "type": "string" },
          "tipo": { "type": "string", "enum": ["semilla", "sustrato"] }
        },
        "required": ["id", "numero_lote", "tipo"]
      },
      "BandejaGroup": {
        "type": "object",
        "description": "A group of identical trays created from the same lot combination",
        "properties": {
          "lote_semilla_id": { "type": "string", "format": "uuid" },
          "lote_sustrato_id": { "type": "string", "format": "uuid" },
          "cantidad": { "type": "integer", "minimum": 1 }
        },
        "required": ["lote_semilla_id", "lote_sustrato_id", "cantidad"]
      },
      "Bandeja": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "tenant_id": { "type": "string", "format": "uuid" },
          "siembra_id": { "type": "string", "format": "uuid" },
          "lote_semilla_id": { "type": "string", "format": "uuid" },
          "lote_sustrato_id": { "type": "string", "format": "uuid" },
          "lote_semilla": { "$ref": "#/components/schemas/LoteRef" },
          "lote_sustrato": { "$ref": "#/components/schemas/LoteRef" },
          "estado": { "$ref": "#/components/schemas/BandejaEstado" },
          "fecha_entrada_nursery": { "type": "string", "format": "date-time" },
          "fecha_trasplante": { "type": "string", "format": "date-time", "nullable": true },
          "mesa_id": { "type": "string", "format": "uuid", "nullable": true },
          "establecimiento_id": { "type": "string", "format": "uuid" },
          "observaciones": { "type": "string", "nullable": true },
          "codigo": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Siembra": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "tenant_id": { "type": "string", "format": "uuid" },
          "establecimiento_id": { "type": "string", "format": "uuid" },
          "fecha": { "type": "string", "format": "date", "example": "2026-06-04" },
          "observaciones": { "type": "string", "nullable": true },
          "usuario_id": { "type": "string", "format": "uuid" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "SiembraWithBandejas": {
        "allOf": [
          { "$ref": "#/components/schemas/Siembra" },
          {
            "type": "object",
            "properties": {
              "bandejas": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Bandeja" }
              }
            }
          }
        ]
      },
      "CreateSiembraDto": {
        "type": "object",
        "properties": {
          "establecimiento_id": { "type": "string", "format": "uuid" },
          "fecha": { "type": "string", "format": "date", "description": "Defaults to today if omitted" },
          "observaciones": { "type": "string", "nullable": true },
          "bandejas": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BandejaGroup" },
            "minItems": 1
          }
        },
        "required": ["establecimiento_id", "bandejas"]
      },
      "UpdateSiembraDto": {
        "type": "object",
        "description": "Only observaciones is accepted. Any other field causes 400 SIEMBRA_FIELD_IMMUTABLE.",
        "properties": {
          "observaciones": { "type": "string", "nullable": true }
        }
      },
      "PagedSiembras": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Siembra" } },
          "meta": { "type": "object", "properties": { "page": { "type": "integer" }, "limit": { "type": "integer" }, "total": { "type": "integer" } } }
        }
      },
      "PagedBandejas": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Bandeja" } },
          "meta": { "type": "object", "properties": { "page": { "type": "integer" }, "limit": { "type": "integer" }, "total": { "type": "integer" } } }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": false },
          "error": { "type": "object", "properties": { "code": { "type": "string" }, "message": { "type": "string" } } }
        }
      }
    }
  },
  "paths": {
    "/siembras": {
      "get": {
        "tags": ["Siembras"],
        "summary": "List seedings — all authenticated users",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 200 } },
          { "name": "establecimiento_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "fecha_desde", "in": "query", "schema": { "type": "string", "format": "date" }, "description": "Filter from date (inclusive)" },
          { "name": "fecha_hasta", "in": "query", "schema": { "type": "string", "format": "date" }, "description": "Filter to date (inclusive)" },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["fecha", "created_at"] } },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["ASC", "DESC"] } }
        ],
        "responses": {
          "200": { "description": "Paginated list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedSiembras" } } } },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Siembras"],
        "summary": "Create seeding with trays atomically — operario, supervisor, admin_global",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateSiembraDto" } } }
        },
        "responses": {
          "201": { "description": "Created — returns siembra with bandejas[]", "content": { "application/json": { "schema": { "type": "object", "properties": { "ok": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/SiembraWithBandejas" } } } } } },
          "400": { "description": "Validation error (empty bandejas, cantidad=0, etc.)" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Establishment or lot not found in tenant" },
          "422": { "description": "LOTE_TIPO_INCORRECTO — lot type mismatch", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/siembras/{id}": {
      "get": {
        "tags": ["Siembras"],
        "summary": "Get seeding with bandejas nested — all authenticated",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Seeding with bandejas array (each bandeja includes lote_semilla and lote_sustrato refs)", "content": { "application/json": { "schema": { "type": "object", "properties": { "ok": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/SiembraWithBandejas" } } } } } },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" }
        }
      },
      "patch": {
        "tags": ["Siembras"],
        "summary": "Update seeding notes — supervisor, admin_global",
        "description": "Only `observaciones` is accepted. Any other field in the body returns 400 SIEMBRA_FIELD_IMMUTABLE.",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateSiembraDto" } } }
        },
        "responses": {
          "200": { "description": "Updated" },
          "400": { "description": "SIEMBRA_FIELD_IMMUTABLE — extra fields detected in body" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "tags": ["Siembras"],
        "summary": "Soft-delete seeding and all its trays — admin_global only",
        "description": "Blocked if any tray is in trasplantada state.",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Deleted" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Not found" },
          "409": { "description": "SIEMBRA_HAS_TRASPLANTADAS — cannot delete seeding with transplanted trays", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/siembras/{id}/bandejas": {
      "get": {
        "tags": ["Siembras"],
        "summary": "List trays of a specific seeding — all authenticated",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Tray list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedBandejas" } } } },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Seeding not found" }
        }
      }
    },
    "/bandejas": {
      "get": {
        "tags": ["Bandejas"],
        "summary": "List nursery trays — all authenticated",
        "description": "Defaults to estado=en_nursery. Pass ?estado=trasplantada to see transplanted trays.",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 200 } },
          { "name": "estado", "in": "query", "schema": { "$ref": "#/components/schemas/BandejaEstado" }, "description": "Defaults to en_nursery if omitted" },
          { "name": "establecimiento_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "siembra_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "lote_semilla_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["fecha_entrada_nursery", "created_at"] } },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["ASC", "DESC"] } }
        ],
        "responses": {
          "200": { "description": "Paginated tray list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedBandejas" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/bandejas/{id}": {
      "get": {
        "tags": ["Bandejas"],
        "summary": "Get tray with siembra + lot info — all authenticated",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Tray with lote_semilla, lote_sustrato references", "content": { "application/json": { "schema": { "type": "object", "properties": { "ok": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/Bandeja" } } } } } },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" }
        }
      }
    }
  }
}
