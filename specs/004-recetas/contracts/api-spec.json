{
  "openapi": "3.0.3",
  "info": {
    "title": "Recetas API — M04",
    "version": "1.0.0",
    "description": "Endpoints for managing nursery recipe references."
  },
  "tags": [
    { "name": "Recetas", "description": "Recipe catalog operations" },
    { "name": "Admin", "description": "Admin-only recipe operations" }
  ],
  "security": [{ "bearerAuth": [] }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "Receta": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "tenant_id": { "type": "string", "format": "uuid" },
          "establecimiento_id": { "type": "string", "format": "uuid" },
          "nombre": { "type": "string", "maxLength": 150 },
          "descripcion": { "type": "string", "nullable": true },
          "activo": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateRecetaDto": {
        "type": "object",
        "required": ["establecimiento_id", "nombre"],
        "properties": {
          "establecimiento_id": { "type": "string", "format": "uuid" },
          "nombre": { "type": "string", "maxLength": 150 },
          "descripcion": { "type": "string", "nullable": true }
        }
      },
      "UpdateRecetaDto": {
        "type": "object",
        "description": "Only nombre, descripcion, activo are accepted. Any other field (e.g. establecimiento_id) causes 400 RECETA_FIELD_IMMUTABLE.",
        "properties": {
          "nombre": { "type": "string", "maxLength": 150 },
          "descripcion": { "type": "string", "nullable": true },
          "activo": { "type": "boolean" }
        }
      },
      "PagedRecetas": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Receta" } },
          "meta": {
            "type": "object",
            "properties": {
              "page": { "type": "integer" },
              "limit": { "type": "integer" },
              "total": { "type": "integer" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/recetas": {
      "get": {
        "tags": ["Recetas"],
        "summary": "List recipes — all authenticated users",
        "description": "Returns all non-deleted recipes. No default activo filter — pass ?activo=true or ?activo=false to filter by status.",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 200 } },
          { "name": "q", "in": "query", "description": "Search by nombre (ILIKE)", "schema": { "type": "string" } },
          { "name": "establecimiento_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "activo", "in": "query", "description": "No default — omit to return all; pass true/false to filter", "schema": { "type": "boolean" } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["nombre", "created_at"] } },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["ASC", "DESC"] } }
        ],
        "responses": {
          "200": { "description": "Paginated list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedRecetas" } } } },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Recetas"],
        "summary": "Create recipe — supervisor, admin_global",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateRecetaDto" } } }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "type": "object", "properties": { "ok": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/Receta" } } } } } },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Establishment not found in tenant" },
          "409": { "description": "RECETA_NOMBRE_DUPLICADO — nombre already exists for this establishment", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/recetas/{id}": {
      "get": {
        "tags": ["Recetas"],
        "summary": "Get recipe by ID — all authenticated",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Recipe record", "content": { "application/json": { "schema": { "type": "object", "properties": { "ok": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/Receta" } } } } } },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" }
        }
      },
      "patch": {
        "tags": ["Recetas"],
        "summary": "Update recipe — supervisor, admin_global",
        "description": "Only nombre, descripcion, activo are accepted. Any other field (e.g. establecimiento_id) returns 400 RECETA_FIELD_IMMUTABLE.",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateRecetaDto" } } }
        },
        "responses": {
          "200": { "description": "Updated" },
          "400": { "description": "RECETA_FIELD_IMMUTABLE — body contains establecimiento_id or other immutable field" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Not found" },
          "409": { "description": "RECETA_NOMBRE_DUPLICADO — new nombre conflicts with existing recipe" }
        }
      },
      "delete": {
        "tags": ["Recetas"],
        "summary": "Soft-delete recipe — admin_global only",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Deleted" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/admin/recetas": {
      "get": {
        "tags": ["Admin"],
        "summary": "Admin list — admin_global only",
        "description": "Returns all non-deleted tenant recipes (both activo=true and activo=false).",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 200 } },
          { "name": "q", "in": "query", "schema": { "type": "string" } },
          { "name": "establecimiento_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "activo", "in": "query", "schema": { "type": "boolean" } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["nombre", "created_at"] } },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["ASC", "DESC"] } }
        ],
        "responses": {
          "200": { "description": "Paginated list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedRecetas" } } } },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden — admin_global only" }
        }
      }
    }
  }
}
