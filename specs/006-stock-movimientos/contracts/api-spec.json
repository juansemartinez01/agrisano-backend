{
  "openapi": "3.0.3",
  "info": {
    "title": "M06 — Stock Movimientos API",
    "version": "1.0.0",
    "description": "Manual stock movement endpoints for chemical inventory management"
  },
  "tags": [
    { "name": "stock-movimientos", "description": "Stock movement CRUD (append-only)" }
  ],
  "paths": {
    "/stock-movimientos": {
      "get": {
        "tags": ["stock-movimientos"],
        "summary": "List stock movements (paginated, filterable)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 20 } },
          { "name": "quimico_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "establecimiento_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "tipo", "in": "query", "schema": { "$ref": "#/components/schemas/MovimientoTipo" } },
          { "name": "fecha_desde", "in": "query", "schema": { "type": "string", "format": "date" }, "description": "Inclusive lower bound for fecha" },
          { "name": "fecha_hasta", "in": "query", "schema": { "type": "string", "format": "date" }, "description": "Inclusive upper bound for fecha" },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["fecha", "created_at"], "default": "fecha" } },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "DESC" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of movements",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MovimientoListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["stock-movimientos"],
        "summary": "Create a stock movement (supervisor, admin_global only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMovimientoDto" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Movement created. Includes updated stock and optional warning.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateMovimientoResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/stock-movimientos/{id}": {
      "get": {
        "tags": ["stock-movimientos"],
        "summary": "Get a single stock movement by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Movement record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MovimientoResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/quimicos/{quimicoId}/movimientos": {
      "get": {
        "tags": ["stock-movimientos"],
        "summary": "List movements for a specific chemical (convenience endpoint)",
        "description": "Equivalent to GET /stock-movimientos?quimico_id={quimicoId}. Validates the chemical exists in the tenant before querying.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "quimicoId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 20 } },
          { "name": "tipo", "in": "query", "schema": { "$ref": "#/components/schemas/MovimientoTipo" } },
          { "name": "fecha_desde", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "fecha_hasta", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["fecha", "created_at"], "default": "fecha" } },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "DESC" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of movements for the chemical",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MovimientoListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "MovimientoTipo": {
        "type": "string",
        "enum": ["ingreso", "egreso_manual"]
      },
      "MovimientoStock": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "tenant_id": { "type": "string", "format": "uuid", "nullable": true },
          "quimico_id": { "type": "string", "format": "uuid" },
          "establecimiento_id": { "type": "string", "format": "uuid" },
          "tipo": { "$ref": "#/components/schemas/MovimientoTipo" },
          "cantidad": { "type": "number", "format": "decimal" },
          "unidad_medida": { "type": "string", "maxLength": 30 },
          "numero_remito": { "type": "string", "maxLength": 100, "nullable": true },
          "observaciones": { "type": "string", "nullable": true },
          "usuario_id": { "type": "string", "format": "uuid" },
          "fecha": { "type": "string", "format": "date" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateMovimientoDto": {
        "type": "object",
        "required": ["quimico_id", "tipo", "cantidad"],
        "properties": {
          "quimico_id": { "type": "string", "format": "uuid" },
          "tipo": { "$ref": "#/components/schemas/MovimientoTipo" },
          "cantidad": { "type": "number", "minimum": 0.001, "description": "Must be > 0" },
          "numero_remito": { "type": "string", "maxLength": 100, "nullable": true },
          "observaciones": { "type": "string", "nullable": true },
          "fecha": { "type": "string", "format": "date", "description": "Defaults to today if omitted" }
        },
        "description": "Fields unidad_medida and establecimiento_id are NOT accepted — always copied from the chemical record."
      },
      "CreateMovimientoResponseData": {
        "type": "object",
        "required": ["movimiento", "quimico_stock_actual"],
        "properties": {
          "movimiento": { "$ref": "#/components/schemas/MovimientoStock" },
          "quimico_stock_actual": {
            "type": "number",
            "description": "Projected stock_actual after this movement (may be negative for egreso_manual)"
          },
          "warning": {
            "type": "string",
            "enum": ["Stock resultante negativo"],
            "description": "Present only when egreso_manual would result in negative stock. Key is omitted (not null) when no warning."
          }
        }
      },
      "MovimientoResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/MovimientoStock" }
        }
      },
      "CreateMovimientoResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/CreateMovimientoResponseData" }
        }
      },
      "MovimientoListResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": true },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MovimientoStock" }
          },
          "meta": {
            "type": "object",
            "properties": {
              "page": { "type": "integer" },
              "limit": { "type": "integer" },
              "total": { "type": "integer" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid JWT",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "Forbidden": {
        "description": "Insufficient role (requires supervisor or admin_global)",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "NotFound": {
        "description": "Resource not found or not in tenant",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "BadRequest": {
        "description": "Validation error",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      }
    }
  }
}
