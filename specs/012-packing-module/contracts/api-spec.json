{
  "openapi": "3.0.3",
  "info": {
    "title": "M12 — Packing (Lote Packing) API",
    "version": "1.0.0",
    "description": "Endpoints for registering and querying harvest packing records with category breakdowns."
  },
  "paths": {
    "/packing": {
      "post": {
        "summary": "Register a packing record for a cosecha",
        "operationId": "registrarPacking",
        "tags": ["Packing"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePackingDto" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Packing registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "lote_packing": { "$ref": "#/components/schemas/LotePacking" },
                        "categorias": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/LotePackingCategoria" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation error (e.g., peso_bruto_kg <= 0, empty categorias)" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden — role not allowed (requires operario, supervisor, or admin_global)" },
          "404": { "description": "COSECHA_NOT_FOUND — cosecha does not exist or belongs to different tenant" },
          "409": { "description": "PACKING_YA_REGISTRADO — cosecha already has a packing record" },
          "422": { "description": "PACKING_CATEGORIA_DUPLICADA — duplicate categoria values in request" }
        }
      },
      "get": {
        "summary": "List all packing records (paginated, filterable by cosecha)",
        "operationId": "listPacking",
        "tags": ["Packing"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 20 } },
          { "name": "cosecha_id", "in": "query", "schema": { "type": "string", "format": "uuid" }, "description": "Filter by cosecha ID" },
          { "name": "sortBy", "in": "query", "schema": { "type": "string" } },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "DESC" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of packing records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/LotePacking" } },
                    "total": { "type": "integer" },
                    "page": { "type": "integer" },
                    "limit": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/packing/{id}": {
      "get": {
        "summary": "Get a single packing record by ID with categorias nested",
        "operationId": "getPackingById",
        "tags": ["Packing"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Packing record with categorias",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "lote_packing": { "$ref": "#/components/schemas/LotePacking" },
                        "categorias": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/LotePackingCategoria" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "PACKING_NOT_FOUND" }
        }
      }
    },
    "/cosechas/{cosecha_id}/packing": {
      "get": {
        "summary": "Get the packing record for a specific cosecha",
        "operationId": "getPackingByCosecha",
        "tags": ["Packing"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "cosecha_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Single packing record with categorias for the given cosecha",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "lote_packing": { "$ref": "#/components/schemas/LotePacking" },
                        "categorias": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/LotePackingCategoria" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "PACKING_NOT_FOUND — no packing exists for this cosecha (or COSECHA_NOT_FOUND if cosecha invalid)" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CreatePackingCategoriaDto": {
        "type": "object",
        "required": ["categoria", "peso_kg", "cantidad_cajas", "peso_neto_por_caja"],
        "properties": {
          "categoria": {
            "type": "string",
            "enum": ["primera", "segunda", "descarte"],
            "description": "Quality tier for this category breakdown"
          },
          "peso_kg": {
            "type": "number",
            "minimum": 0.001,
            "maximum": 9999999.999,
            "description": "Weight in kilograms for this category (3 decimal places)"
          },
          "cantidad_cajas": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of boxes in this category"
          },
          "peso_neto_por_caja": {
            "type": "number",
            "minimum": 0.001,
            "maximum": 9999999.999,
            "description": "Net weight per box in kilograms (3 decimal places)"
          }
        }
      },
      "CreatePackingDto": {
        "type": "object",
        "required": ["cosecha_id", "peso_bruto_kg", "categorias"],
        "properties": {
          "cosecha_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the cosecha being packed (must belong to same tenant)"
          },
          "peso_bruto_kg": {
            "type": "number",
            "minimum": 0.001,
            "maximum": 9999999.999,
            "description": "Total gross weight of the packing batch in kilograms"
          },
          "observaciones": {
            "type": "string",
            "maxLength": 1000,
            "nullable": true,
            "description": "Optional free-form notes"
          },
          "categorias": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": { "$ref": "#/components/schemas/CreatePackingCategoriaDto" },
            "description": "Category breakdowns (1–3, no duplicate categoria values)"
          }
        }
      },
      "LotePacking": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "tenant_id": { "type": "string", "format": "uuid", "nullable": true },
          "cosecha_id": { "type": "string", "format": "uuid" },
          "fecha_hora": { "type": "string", "format": "date-time", "description": "Server-side packing timestamp" },
          "peso_bruto_kg": { "type": "number", "description": "Total gross weight (decimal 10,3)" },
          "usuario_id": { "type": "string", "format": "uuid", "description": "User who registered the packing (from JWT)" },
          "observaciones": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "LotePackingCategoria": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "lote_packing_id": { "type": "string", "format": "uuid" },
          "categoria": { "type": "string", "enum": ["primera", "segunda", "descarte"] },
          "peso_kg": { "type": "number", "description": "Weight in this category (decimal 10,3)" },
          "cantidad_cajas": { "type": "integer", "description": "Number of boxes" },
          "peso_neto_por_caja": { "type": "number", "description": "Net weight per box (decimal 10,3)" }
        }
      }
    }
  }
}
